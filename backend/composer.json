{
  "name": "examguard/backend",
  "description": "Yii2 REST backend for ExamGuard classroom exam monitoring.",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "yiisoft/yii2": "~2.0.49"
  },
  "autoload": {
    "psr-4": {
      "app\\": ""
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}
